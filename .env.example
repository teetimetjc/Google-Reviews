GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# For the manual Places API scan (src/places-check.js) — no GBP approval needed
PLACES_API_KEY=
PLACE_ID=
BUSINESS_NAME=

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

EMAIL_FROM=
EMAIL_TO=

# Set to "true" to always send a digest, even when there's nothing to flag
ALWAYS_SEND=false

# Google Sheets service account (Reviews Log / Change Log tabs)
SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_SERVICE_ACCOUNT_KEY=

# AI draft replies (scripts/generate-draft-responses.js) — human reviews and
# copy/pastes every draft, nothing is auto-posted to Google.
ANTHROPIC_API_KEY=
# Optional: how many drafts to generate per run (default 25) — mainly a
# safety cap for the first run against a sheet with years of backfill.
MAX_DRAFTS_PER_RUN=25
# Optional: get a push notification when new drafts are ready.
PUSHOVER_TOKEN=
PUSHOVER_USER=
